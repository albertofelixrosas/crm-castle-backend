{
  "info": {
    "name": "CRM Castle API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Lead",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/leads",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leads"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ana\",\n  \"lastName\": \"Lopez\",\n  \"email\": \"ana.lopez@example.com\",\n  \"phone\": \"+34-600-000-001\",\n  \"companyName\": \"Acme Corp\",\n  \"source\": \"Website\",\n  \"notes\": \"Interested in enterprise plan\"\n}"
        }
      }
    },
    {
      "name": "List Leads",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/leads?page=0&size=20&sort=createdAt,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leads"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" },
            { "key": "sort", "value": "createdAt,desc" }
          ]
        }
      }
    },
    {
      "name": "Get Lead By Id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/leads/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leads", "1"]
        }
      }
    },
    {
      "name": "Convert Lead",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{baseUrl}}/api/v1/leads/1/convert",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leads", "1", "convert"]
        }
      }
    },
    {
      "name": "List Contacts",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/contacts?page=0&size=20&sort=createdAt,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "contacts"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" },
            { "key": "sort", "value": "createdAt,desc" }
          ]
        }
      }
    },
    {
      "name": "List Companies",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/companies?page=0&size=20&sort=createdAt,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "companies"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "20" },
            { "key": "sort", "value": "createdAt,desc" }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ]
}
